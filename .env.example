DB_URL=jdbc:postgresql://localhost:5432/collabkart
DB_USERNAME=collabkart
DB_PASSWORD=collabkart
JWT_SECRET=change-this-to-a-very-long-secret-with-at-least-32-characters
JWT_EXPIRATION_MS=86400000
SERVER_PORT=8080
DEV_ADMIN_EMAIL=admin@collabkart.local
DEV_ADMIN_PASSWORD=Admin@12345
DEV_ADMIN_NAME=Dev Admin
APP_UPLOAD_DIR=uploads
APP_PUBLIC_BASE_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudinary is required for deployed image uploads. Local dev falls back to APP_UPLOAD_DIR if these are blank.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=collabkart
